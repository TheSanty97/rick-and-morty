---
---

<!-- ===== Hero ===== -->
<header class="relative px-4 pt-14 pb-8 text-center">
  <div class="mx-auto mb-6 flex items-center justify-center">
    <div class="flex items-center -space-x-4">
      <div class="relative h-20 w-20">
        <div class="portal-ring absolute inset-0"></div>
        <img
          src="https://rickandmortyapi.com/api/character/avatar/1.jpeg"
          alt="Rick Sanchez"
          class="absolute inset-[5px] h-[calc(100%-10px)] w-[calc(100%-10px)] rounded-full object-cover"
        />
      </div>
      <div class="relative z-10 h-20 w-20">
        <div class="portal-ring absolute inset-0"></div>
        <img
          src="https://rickandmortyapi.com/api/character/avatar/2.jpeg"
          alt="Morty Smith"
          class="absolute inset-[5px] h-[calc(100%-10px)] w-[calc(100%-10px)] rounded-full object-cover"
        />
      </div>
    </div>
  </div>
  <h1 class="portal-title text-5xl leading-none sm:text-7xl md:text-8xl">
    Rick and Morty
  </h1>
  <p class="mx-auto mt-4 max-w-xl text-sm text-[var(--text-soft)] sm:text-base">
    Explora el multiverso. Busca, filtra y descubre cada personaje de la dimensión
    C-137 y más allá.
  </p>
</header>

<!-- ===== Controls ===== -->
<section class="mx-auto max-w-6xl px-4">
  <div
    class="sticky top-3 z-30 rounded-2xl border border-[var(--border-soft)] bg-[rgba(11,14,20,0.75)] p-3 backdrop-blur-md"
  >
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <div class="relative">
        <span
          class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-[var(--text-soft)]"
          >🔍</span
        >
        <input
          id="nameFilter"
          type="text"
          placeholder="Buscar por nombre…"
          class="control-input pl-9"
          autocomplete="off"
        />
      </div>
      <select id="speciesFilter" class="control-input">
        <option value="">Especie: Todas</option>
        <option value="Human">Humano</option>
        <option value="Alien">Alienígena</option>
        <option value="Humanoid">Humanoide</option>
        <option value="Robot">Robot</option>
        <option value="Animal">Animal</option>
        <option value="Mythological Creature">Criatura mitológica</option>
        <option value="Cronenberg">Cronenberg</option>
        <option value="Poopybutthole">Poopybutthole</option>
        <option value="Disease">Enfermedad</option>
        <option value="unknown">Desconocida</option>
      </select>
      <select id="statusFilter" class="control-input">
        <option value="">Estado: Todos</option>
        <option value="alive">Vivo</option>
        <option value="dead">Muerto</option>
        <option value="unknown">Desconocido</option>
      </select>
      <select id="genderFilter" class="control-input">
        <option value="">Género: Todos</option>
        <option value="male">Masculino</option>
        <option value="female">Femenino</option>
        <option value="genderless">Sin género</option>
        <option value="unknown">Desconocido</option>
      </select>
    </div>
  </div>

  <!-- Result count -->
  <div class="mt-4 flex items-center justify-between px-1">
    <p id="resultCount" class="text-sm text-[var(--text-soft)]">Cargando…</p>
    <button id="resetBtn" class="text-sm text-[var(--portal-green)] hover:underline">
      Limpiar filtros
    </button>
  </div>
</section>

<!-- ===== Grid ===== -->
<section class="mx-auto max-w-6xl px-4 pb-10">
  <div
    id="charactersGrid"
    class="mt-4 grid grid-cols-1 gap-5 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
  >
  </div>

  <!-- Empty / error state -->
  <div id="emptyState" class="hidden flex-col items-center py-20 text-center">
    <div class="text-6xl">🛸</div>
    <p id="emptyText" class="mt-4 text-lg font-semibold text-white">
      No se encontraron personajes
    </p>
    <p class="mt-1 text-sm text-[var(--text-soft)]">
      Prueba con otros filtros o limpia la búsqueda.
    </p>
  </div>
</section>

<!-- ===== Pagination ===== -->
<section class="mx-auto max-w-6xl px-4 pb-16">
  <div class="flex items-center justify-center gap-4">
    <button id="prevBtn" class="btn-portal" disabled>← Anterior</button>
    <span
      id="pageIndicator"
      class="min-w-28 text-center text-sm font-medium text-white"
      >Página 1</span
    >
    <button id="nextBtn" class="btn-portal" disabled>Siguiente →</button>
  </div>
</section>

<!-- ===== Modal ===== -->
<div id="modal" class="modal-backdrop">
  <div class="modal-panel" role="dialog" aria-modal="true">
    <div
      class="relative flex flex-col items-center px-5 pt-8 pb-2 bg-gradient-to-b from-[rgba(151,206,76,0.12)] to-transparent"
    >
      <button
        id="modalClose"
        class="absolute right-3 top-3 flex h-9 w-9 items-center justify-center rounded-full bg-black/50 text-white transition hover:bg-black/80"
        aria-label="Cerrar"
      >
        ✕
      </button>
      <div class="relative h-32 w-32">
        <div class="portal-ring absolute inset-0"></div>
        <img
          id="modalImg"
          src=""
          alt=""
          class="absolute inset-[5px] h-[calc(100%-10px)] w-[calc(100%-10px)] rounded-full object-cover object-top"
        />
      </div>
      <h2 id="modalName" class="mt-4 text-center text-2xl font-bold text-white"></h2>
      <div class="mt-1 flex items-center gap-2">
        <span id="modalStatusDot" class="status-dot"></span>
        <span id="modalStatusText" class="text-sm text-[var(--text-soft)]"></span>
      </div>
    </div>
    <div class="px-5 pb-5 pt-3">
      <dl class="mt-5 space-y-3 text-sm">
        <div class="flex justify-between gap-4 border-b border-white/5 pb-2">
          <dt class="text-[var(--text-soft)]">Origen</dt>
          <dd id="modalOrigin" class="text-right font-medium text-white"></dd>
        </div>
        <div class="flex justify-between gap-4 border-b border-white/5 pb-2">
          <dt class="text-[var(--text-soft)]">Ubicación actual</dt>
          <dd id="modalLocation" class="text-right font-medium text-white"></dd>
        </div>
        <div class="flex justify-between gap-4 border-b border-white/5 pb-2">
          <dt class="text-[var(--text-soft)]">Género</dt>
          <dd id="modalGender" class="text-right font-medium text-white"></dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-[var(--text-soft)]">Episodios</dt>
          <dd id="modalEpisodes" class="text-right font-medium text-white"></dd>
        </div>
      </dl>
    </div>
  </div>
</div>

<script type="module">
  const API = "https://rickandmortyapi.com/api/character";

  const els = {
    grid: document.getElementById("charactersGrid"),
    name: document.getElementById("nameFilter"),
    species: document.getElementById("speciesFilter"),
    status: document.getElementById("statusFilter"),
    gender: document.getElementById("genderFilter"),
    reset: document.getElementById("resetBtn"),
    prev: document.getElementById("prevBtn"),
    next: document.getElementById("nextBtn"),
    pageIndicator: document.getElementById("pageIndicator"),
    resultCount: document.getElementById("resultCount"),
    empty: document.getElementById("emptyState"),
    emptyText: document.getElementById("emptyText"),
    modal: document.getElementById("modal"),
    modalClose: document.getElementById("modalClose"),
    modalImg: document.getElementById("modalImg"),
    modalName: document.getElementById("modalName"),
    modalStatusDot: document.getElementById("modalStatusDot"),
    modalStatusText: document.getElementById("modalStatusText"),
    modalOrigin: document.getElementById("modalOrigin"),
    modalLocation: document.getElementById("modalLocation"),
    modalGender: document.getElementById("modalGender"),
    modalEpisodes: document.getElementById("modalEpisodes"),
  };

  let page = 1;
  let info = {};
  let lastResults = [];
  let requestToken = 0;

  const STATUS_ES = { Alive: "Vivo", Dead: "Muerto", unknown: "Desconocido" };
  const GENDER_ES = {
    Male: "Masculino",
    Female: "Femenino",
    Genderless: "Sin género",
    unknown: "Desconocido",
  };

  const statusClass = (s) =>
    s === "Alive" ? "status-alive" : s === "Dead" ? "status-dead" : "status-unknown";

  const escapeHtml = (str = "") =>
    str.replace(
      /[&<>"']/g,
      (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" })[c]
    );

  function buildUrl() {
    const params = new URLSearchParams({ page: String(page) });
    const name = els.name.value.trim();
    const species = els.species.value.trim();
    if (name) params.set("name", name);
    if (species) params.set("species", species);
    if (els.status.value) params.set("status", els.status.value);
    if (els.gender.value) params.set("gender", els.gender.value);
    return `${API}?${params.toString()}`;
  }

  function showSkeletons() {
    els.empty.classList.add("hidden");
    els.empty.classList.remove("flex");
    els.grid.innerHTML = Array.from({ length: 8 })
      .map(
        () => `
        <div class="skeleton-card">
          <div class="skeleton-shimmer aspect-square w-full"></div>
          <div class="p-4 space-y-3">
            <div class="skeleton-shimmer h-4 w-3/4 rounded"></div>
            <div class="skeleton-shimmer h-3 w-1/2 rounded"></div>
            <div class="skeleton-shimmer h-3 w-2/3 rounded"></div>
          </div>
        </div>`
      )
      .join("");
  }

  async function fetchCharacters() {
    const token = ++requestToken;
    showSkeletons();
    els.resultCount.textContent = "Buscando en el multiverso…";

    try {
      const res = await fetch(buildUrl());
      if (token !== requestToken) return;

      if (!res.ok) {
        info = {};
        lastResults = [];
        renderEmpty("No se encontraron personajes con esos filtros");
        updatePagination();
        els.resultCount.textContent = "0 personajes";
        return;
      }

      const data = await res.json();
      if (token !== requestToken) return;

      info = data.info || {};
      lastResults = data.results || [];
      renderCharacters(lastResults);
      updatePagination();
      els.resultCount.textContent = `${info.count.toLocaleString("es")} personajes encontrados`;
    } catch (err) {
      if (token !== requestToken) return;
      info = {};
      lastResults = [];
      renderEmpty("Error de conexión. Revisa tu internet e inténtalo de nuevo.");
      updatePagination();
      els.resultCount.textContent = "Sin conexión";
    }
  }

  function renderEmpty(message) {
    els.grid.innerHTML = "";
    els.emptyText.textContent = message;
    els.empty.classList.remove("hidden");
    els.empty.classList.add("flex");
  }

  function renderCharacters(characters) {
    if (!characters.length) {
      renderEmpty("No se encontraron personajes");
      return;
    }
    els.empty.classList.add("hidden");
    els.empty.classList.remove("flex");

    els.grid.innerHTML = characters
      .map((c, i) => {
        const statusEs = STATUS_ES[c.status] || c.status;
        return `
        <article class="character-card" data-id="${c.id}" style="animation-delay:${i * 40}ms" tabindex="0" role="button" aria-label="Ver detalles de ${escapeHtml(c.name)}">
          <div class="relative">
            <img src="${c.image}" alt="${escapeHtml(c.name)}" loading="lazy" />
            <span class="absolute left-3 top-3 flex items-center gap-1.5 rounded-full bg-black/60 px-2.5 py-1 text-xs font-medium text-white backdrop-blur">
              <span class="status-dot ${statusClass(c.status)}"></span>${statusEs}
            </span>
          </div>
          <div class="p-4">
            <h3 class="truncate text-base font-semibold text-white">${escapeHtml(c.name)}</h3>
            <p class="mt-0.5 text-sm text-[var(--text-soft)]">${escapeHtml(c.species)}${c.type ? " · " + escapeHtml(c.type) : ""}</p>
            <p class="mt-2 text-xs text-[var(--text-soft)]">
              <span class="text-white/50">Última ubicación</span><br />
              ${escapeHtml(c.location?.name || "Desconocida")}
            </p>
          </div>
        </article>`;
      })
      .join("");
  }

  function updatePagination() {
    const totalPages = info.pages || 1;
    els.pageIndicator.textContent = `Página ${page} de ${totalPages}`;
    els.prev.disabled = !info.prev;
    els.next.disabled = !info.next;
  }

  // ===== Modal =====
  function openModal(id) {
    const c = lastResults.find((x) => String(x.id) === String(id));
    if (!c) return;
    els.modalImg.src = c.image;
    els.modalImg.alt = c.name;
    els.modalName.textContent = c.name;
    els.modalStatusDot.className = `status-dot ${statusClass(c.status)}`;
    els.modalStatusText.textContent = `${STATUS_ES[c.status] || c.status} · ${escapeHtml(c.species)}`;
    els.modalOrigin.textContent = c.origin?.name || "Desconocido";
    els.modalLocation.textContent = c.location?.name || "Desconocida";
    els.modalGender.textContent = GENDER_ES[c.gender] || c.gender;
    els.modalEpisodes.textContent = `${c.episode?.length || 0} apariciones`;
    els.modal.classList.add("is-open");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    els.modal.classList.remove("is-open");
    document.body.style.overflow = "";
  }

  // ===== Events =====
  let debounceTimer;
  const debouncedSearch = () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      page = 1;
      fetchCharacters();
    }, 350);
  };

  els.name.addEventListener("input", debouncedSearch);
  const onFilterChange = () => {
    page = 1;
    fetchCharacters();
  };
  els.species.addEventListener("change", onFilterChange);
  els.status.addEventListener("change", onFilterChange);
  els.gender.addEventListener("change", onFilterChange);

  els.reset.addEventListener("click", () => {
    els.name.value = "";
    els.species.value = "";
    els.status.value = "";
    els.gender.value = "";
    page = 1;
    fetchCharacters();
  });

  els.prev.addEventListener("click", () => {
    if (info.prev) {
      page--;
      fetchCharacters();
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  });

  els.next.addEventListener("click", () => {
    if (info.next) {
      page++;
      fetchCharacters();
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  });

  els.grid.addEventListener("click", (e) => {
    const card = e.target.closest(".character-card");
    if (card) openModal(card.dataset.id);
  });
  els.grid.addEventListener("keydown", (e) => {
    if (e.key === "Enter" || e.key === " ") {
      const card = e.target.closest(".character-card");
      if (card) {
        e.preventDefault();
        openModal(card.dataset.id);
      }
    }
  });

  els.modalClose.addEventListener("click", closeModal);
  els.modal.addEventListener("click", (e) => {
    if (e.target === els.modal) closeModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });

  fetchCharacters();
</script>
